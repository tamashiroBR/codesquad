{
  "name": "codesquad-ai",
  "version": "0.1.15",
  "description": "Multi-agent orchestration for software teams — AI squads that spec, build, test, refactor, and review code",
  "type": "module",
  "bin": {
    "codesquad": "bin/codesquad.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/ bin/ tests/",
    "version": "node -e \"require('fs').writeFileSync('templates/_codesquad/.codesquad-version', require('./package.json').version + '\\n')\" && git add templates/_codesquad/.codesquad-version",
    "squads:seed": "node scripts/seed-squads.mjs"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "squads",
    "software-development",
    "code-review",
    "ai-pair-programming",
    "developer-tools",
    "refactoring",
    "testing"
  ],
  "author": "Marcio Tamashiro (https://github.com/tamashiroBR)",
  "homepage": "https://github.com/tamashiroBR/codesquad#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamashiroBR/codesquad.git"
  },
  "bugs": {
    "url": "https://github.com/tamashiroBR/codesquad/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "skills/",
    "templates/",
    "_codesquad/",
    "dashboard/"
  ],
  "dependencies": {
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/input": "^5.0.0",
    "@inquirer/select": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0"
  },
  "contributors": [
    "Renato Asse (https://github.com/renatoasse) — original author of opensquad"
  ]
}
